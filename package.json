{
  "name": "nubbi",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "client": "pnpm dev:client",
    "server": "pnpm dev:server",
    "dev:client": "pnpm --filter nubbi-client dev",
    "dev:server": "pnpm --filter nubbi-server dev",
    "build:client": "pnpm --filter nubbi-client build",
    "lint:client": "pnpm --filter nubbi-client lint",
    "typecheck:server": "pnpm --filter nubbi-server typecheck",
    "prepare": "husky",
    "commit": "git-cz",
    "preflight": "node scripts/preflight.mjs",
    "preflight:no-docker": "node scripts/preflight.mjs --no-docker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-angular": "^21.1.0",
    "@commitlint/prompt": "^21.1.0",
    "commitizen": "^4.3.2",
    "husky": "^9.1.7"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@commitlint/prompt"
    }
  }
}
