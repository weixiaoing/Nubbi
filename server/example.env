# MongoDB
MONGO_URI=

# Server
SERVER_PORT=4000
SOCKET_PORT=4040

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Optional: web search for Note AI.
# WEB_SEARCH_PROVIDER supports tavily / brave / serpapi / searxng.
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=

# Optional: use a preset email service, e.g. qq / gmail
# EMAIL_SERVICE=qq

# Optional: custom SMTP server
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
