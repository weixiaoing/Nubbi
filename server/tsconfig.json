{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "nodenext",
    "paths": {
      "@/*": ["./app/*"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "transpileOnly": true,
    "files": true
  },
  "include": ["app/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
