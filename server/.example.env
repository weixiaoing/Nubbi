# MongoDB
# Docker Compose 本地示例：mongodb://mongo:27017/nubbi
# 外部 MongoDB 示例：mongodb://user:password@example.com:27017/nubbi
MONGO_URI=mongodb://mongo:27017/nubbi
MONGO_DB_NAME=Nubbi

# 服务端端口
SERVER_PORT=4000
SOCKET_PORT=4040

# 对外访问地址
# 生产环境请换成真实域名，例如：
# BETTER_AUTH_URL=https://api.example.com
# CLIENT_URL=https://example.com
BETTER_AUTH_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# Better Auth
# 生产环境请使用强随机密钥。
BETTER_AUTH_SECRET=

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 兼容旧拼写字段。
# 新配置优先使用 AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET。
AUTH_GOOLE_ID=
AUTH_GOOLE_SECRET=

# 邮件配置
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# 可选：使用预设邮件服务，例如 qq / gmail。
EMAIL_SERVICE=

# 可选：自定义 SMTP 服务。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false

# 可选：AI 配置加密/签名密钥。
AI_CONFIG_SECRET=

# 可选：服务端 GitHub 图床配置。
# GH_IMAGE_REPO 格式：owner/repo
# GH_IMAGE_BRANCH 默认为 main。
GH_IMAGE_REPO=
GH_IMAGE_TOKEN=
GH_IMAGE_BRANCH=main

# 可选：Note AI 联网搜索配置。
# WEB_SEARCH_PROVIDER 支持 tavily / brave / serpapi / searxng。
WEB_SEARCH_PROVIDER=
WEB_SEARCH_API_KEY=
WEB_SEARCH_BASE_URL=
